# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional — Brave Search (free tier: 2000 queries/month)
# Get at: https://api.search.brave.com/
BRAVE_API_KEY=

# Optional — fallback LLM (if Groq rate-limits)
OPENAI_API_KEY=

# App config
MAX_PLATFORMS_PER_SEARCH=5
SEARCH_TIMEOUT_SECONDS=30
PLAYWRIGHT_HEADLESS=true
CHROMADB_PATH=./data/chroma
LOG_LEVEL=INFO
