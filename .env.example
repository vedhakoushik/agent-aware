# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional — Brave Search (free tier: 2000 queries/month)
# Get at: https://api.search.brave.com/
BRAVE_API_KEY=

# Optional — fallback LLM (if Groq rate-limits)
OPENAI_API_KEY=

# App config
MAX_PLATFORMS_PER_SEARCH=5
SEARCH_TIMEOUT_SECONDS=30
PLAYWRIGHT_HEADLESS=true
CHROMADB_PATH=./data/chroma
LOG_LEVEL=INFO

# Selenium + BeautifulSoup search tier — fast deterministic scrape tried before
# browser-use on every platform. See backend/tools/selenium_scraper.py / DESIGN.md.
SELENIUM_ENABLED=true
SELENIUM_UNDETECTED=false
SELENIUM_HEADLESS=true
SELENIUM_TIMEOUT=6
SELENIUM_USER_DATA_DIR=
